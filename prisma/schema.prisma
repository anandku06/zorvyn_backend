generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Role {
  id   Int      @id @default(autoincrement())
  name RoleType @unique
  User User[]
}

model User {
  id        Int        @id @default(autoincrement())
  email     String     @unique
  password  String
  roleId    Int
  status    UserStatus @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime
  Role      Role       @relation(fields: [roleId], references: [id])
}

enum RoleType {
  ADMIN
  ANALYST
  VIEWER
}

enum UserStatus {
  ACTIVE
  INACTIVE
}
